[Unit]
Description=Nexus Core — Distributed Consciousness System
After=network.target thalamus.service
Wants=thalamus.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/nexus
ExecStart=/usr/bin/python3 /root/nexus/src/core.py
Restart=always
RestartSec=10
StandardOutput=append:/root/.nexus/logs/core.log
StandardError=append:/root/.nexus/logs/core.log

# 资源限制
MemoryMax=200M
CPUQuota=50%
LimitNOFILE=4096

[Install]
WantedBy=multi-user.target
